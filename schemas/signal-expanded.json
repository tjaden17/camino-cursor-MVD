{
  "$id": "https://camin.local/schemas/signal-expanded.json",
  "title": "SignalExpanded",
  "type": "object",
  "required": [
    "kind",
    "kpiId",
    "execSummary",
    "takeawayBreakdown",
    "provenance"
  ],
  "properties": {
    "kind": { "const": "signal_expanded" },
    "kpiId": { "type": "string", "minLength": 1 },
    "execSummary": { "type": "string", "minLength": 1 },
    "takeawayBreakdown": {
      "type": "object",
      "required": ["directionGoodOrBad", "expectedOrUnexpected"],
      "properties": {
        "directionGoodOrBad": { "type": "string" },
        "expectedOrUnexpected": { "type": "string" }
      },
      "additionalProperties": false
    },
    "benchmarkComparison": { "type": "string" },
    "rootCauseAnalysis": { "type": "string" },
    "rootCauseRationale": { "type": "string" },
    "provenance": { "$ref": "https://camin.local/schemas/provenance.json" }
  },
  "additionalProperties": false
}
