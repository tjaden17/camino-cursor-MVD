{
  "name": "camin-mvd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "validate:onboarding": "tsx src/validate-onboarding.ts",
    "pipeline": "tsx src/pipeline/cli.ts",
    "lint": "eslint src",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "ci": "npm run build && npm run validate:onboarding && npm run test && npm run lint && npm run qc && npm run build --prefix apps/qc-ui",
    "qc": "tsx src/cli.ts",
    "review:gates": "tsx src/review/cli.ts",
    "qc:build": "npm run build && node dist/cli.js",
    "serve:debug": "tsx src/serve-debug.ts",
    "qc-ui:dev": "npm run qc-ui:build && PORT=3050 node apps/qc-ui/.output/server/index.mjs",
    "qc-ui:build": "npm run build && npm run build --prefix apps/qc-ui"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ajv": "^8.17.1",
    "csv-parse": "^5.6.0"
  }
}
